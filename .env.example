# PostgreSQL
POSTGRES_DB=music_platform
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres

# API
API_PORT=8000

# Database URLs
# Keep DATABASE_URL aligned with the Compose service host "db".
# Keep DATABASE_URL_HOST aligned with localhost for host-side Alembic commands.
# If the password contains reserved URL characters, URL-encode it in both values.
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/music_platform
DATABASE_URL_HOST=postgresql+psycopg://postgres:postgres@localhost:5432/music_platform

# Startup database checks
STARTUP_DB_MAX_RETRIES=20
STARTUP_DB_RETRY_SECONDS=2
